# Local Development
DATABASE_URL=sqlite:////tmp/market.db

# For Vercel/serverless (use in-memory or external database)
# Uncomment one of the following for Vercel deployment:

# Option 1: In-memory SQLite (data lost on restart - dev only)
# DATABASE_URL=sqlite:///:memory:

# Option 2: PostgreSQL (recommended for production)
# DATABASE_URL=postgresql://user:password@host:port/database

# API Keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.longcat.chat/openai

# For Google Colab / Ngrok
NGROK_AUTH_TOKEN=your_ngrok_token_here
